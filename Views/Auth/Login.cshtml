@model FreyaCare.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center align-items-center min-vh-75">
        <div class="col-md-5">
            <div class="card shadow p-2">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">Welcome Back</h2>
                        <p class="text-muted mb-0">Sign in to access your FreyaCare dashboard</p>
                    </div>

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="PersonalCode" class="form-label fw-semibold"></label>
                            <input asp-for="PersonalCode" class="form-control form-control-lg" placeholder="Enter your personal code" />
                            <span asp-validation-for="PersonalCode" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Login
                        </button>
                    </form>

                    <div class="mt-4 text-center">
                        <span class="text-muted">Don’t have an account?</span>
                        <a asp-controller="Auth" asp-action="Register" class="fw-semibold text-decoration-none ms-1">
                            Create a new account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>