@{
    ViewData["Title"] = "FreyaCare";
}

<style>
    :root {
        --fc-navy: #071f2f;
        --fc-navy-soft: #0d344b;
        --fc-blue: #0078d4;
        --fc-cyan: #66d9ff;
        --fc-cream: #f6fbff;
        --fc-text: #132733;
        --fc-muted: #6b7280;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: #f6fbff;
        color: var(--fc-text);
    }

    .lux-hero {
        min-height: 92vh;
        position: relative;
        display: flex;
        align-items: center;
        overflow: hidden;
        color: white;
        background: linear-gradient(90deg, rgba(7,31,47,0.96) 0%, rgba(7,31,47,0.82) 45%, rgba(7,31,47,0.35) 100%), url('/images/hero_doctor.png');
        background-size: cover;
        background-position: center right;
    }

        .lux-hero::before {
            content: "";
            position: absolute;
            inset: 28px;
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 34px;
            pointer-events: none;
        }

        .lux-hero::after {
            content: "";
            position: absolute;
            width: 520px;
            height: 520px;
            right: -160px;
            bottom: -160px;
            background: radial-gradient(circle, rgba(102,217,255,0.28), transparent 65%);
        }

    .hero-inner {
        position: relative;
        z-index: 2;
        max-width: 820px;
        padding-top: 6rem;
        padding-bottom: 6rem;
    }

    .eyebrow {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 4px;
        font-size: 0.78rem;
        font-weight: 800;
        color: var(--fc-cyan);
        margin-bottom: 1.4rem;
    }

    .lux-title {
        font-size: clamp(3.4rem, 8vw, 7.6rem);
        line-height: 0.9;
        font-weight: 900;
        letter-spacing: -4px;
        margin-bottom: 1.6rem;
    }

        .lux-title span {
            color: var(--fc-cyan);
        }

    .lux-lead {
        max-width: 660px;
        font-size: 1.25rem;
        line-height: 1.8;
        color: rgba(255,255,255,0.82);
        margin-bottom: 2.2rem;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-lux-primary,
    .btn-lux-light,
    .btn-lux-dark {
        border-radius: 999px;
        padding: 0.95rem 1.8rem;
        font-weight: 800;
        transition: all 0.25s ease;
    }

    .btn-lux-primary {
        background: linear-gradient(135deg, #66d9ff, #0078d4);
        color: white;
        border: none;
        box-shadow: 0 18px 35px rgba(0,120,212,0.35);
    }

        .btn-lux-primary:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 24px 45px rgba(0,120,212,0.45);
        }

    .btn-lux-light {
        color: white;
        border: 1px solid rgba(255,255,255,0.45);
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
    }

        .btn-lux-light:hover {
            color: white;
            background: rgba(255,255,255,0.16);
            transform: translateY(-3px);
        }

    .hero-stat-bar {
        position: relative;
        z-index: 3;
        margin-top: -5rem;
    }

    .stat-wrap {
        background: rgba(255,255,255,0.92);
        border-radius: 30px;
        padding: 1.5rem;
        box-shadow: 0 30px 70px rgba(7,31,47,0.18);
        backdrop-filter: blur(14px);
    }

    .stat-item {
        padding: 1.2rem;
        border-right: 1px solid rgba(15,23,42,0.08);
    }

        .stat-item:last-child {
            border-right: 0;
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 900;
        color: var(--fc-blue);
        margin-bottom: 0.2rem;
    }

    .stat-label {
        color: var(--fc-muted);
        margin: 0;
    }

    .lux-section {
        padding: 6rem 0;
    }

    .section-kicker {
        color: var(--fc-blue);
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 0.8rem;
        font-weight: 900;
        margin-bottom: 1rem;
    }

    .section-title {
        font-size: clamp(2.4rem, 5vw, 4.8rem);
        line-height: 1;
        font-weight: 900;
        letter-spacing: -2px;
        color: var(--fc-text);
    }

    .section-copy {
        color: var(--fc-muted);
        font-size: 1.15rem;
        line-height: 1.8;
    }

    .lux-card {
        border: 0;
        border-radius: 32px;
        background: white;
        box-shadow: 0 24px 60px rgba(15,23,42,0.08);
        overflow: hidden;
        height: 100%;
        transition: all 0.25s ease;
    }

        .lux-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 34px 75px rgba(15,23,42,0.13);
        }

    .lux-card-body {
        padding: 2rem;
    }

    .lux-card img {
        width: 100%;
        height: 280px;
        object-fit: cover;
    }

    .lux-card h3 {
        font-weight: 900;
        color: var(--fc-text);
        margin-bottom: 1rem;
    }

    .lux-card p {
        color: var(--fc-muted);
        line-height: 1.7;
    }

    .step-card {
        position: relative;
        padding: 2rem;
        border-radius: 30px;
        background: linear-gradient(145deg, white, #eef8ff);
        box-shadow: 0 20px 50px rgba(15,23,42,0.08);
        height: 100%;
        overflow: hidden;
    }

        .step-card::after {
            content: "";
            position: absolute;
            width: 180px;
            height: 180px;
            right: -80px;
            top: -80px;
            background: radial-gradient(circle, rgba(0,120,212,0.18), transparent 70%);
        }

    .step-number {
        font-size: 3rem;
        font-weight: 900;
        color: rgba(0,120,212,0.18);
        margin-bottom: 1.5rem;
    }

    .step-card h3 {
        font-weight: 900;
        margin-bottom: 0.8rem;
    }

    .step-card p {
        color: var(--fc-muted);
        margin-bottom: 0;
    }

    .dark-feature {
        padding: 6rem 0;
        background: linear-gradient(135deg, rgba(7,31,47,0.96), rgba(13,52,75,0.96)), url('/images/doctor_medicine.png');
        background-size: cover;
        background-position: center;
        color: white;
    }

    .dark-panel {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 34px;
        padding: 3rem;
        backdrop-filter: blur(12px);
    }

        .dark-panel h2 {
            font-size: clamp(2.4rem, 5vw, 4.6rem);
            line-height: 1;
            font-weight: 900;
            letter-spacing: -2px;
        }

        .dark-panel p {
            color: rgba(255,255,255,0.8);
            font-size: 1.15rem;
            line-height: 1.8;
        }

    .feature-list {
        list-style: none;
        padding: 0;
        margin: 2rem 0 0;
    }

        .feature-list li {
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            margin-bottom: 1rem;
            color: rgba(255,255,255,0.86);
            font-size: 1.05rem;
        }

    .check-dot {
        width: 30px;
        height: 30px;
        min-width: 30px;
        border-radius: 999px;
        background: var(--fc-cyan);
        color: var(--fc-navy);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
    }

    .contact-card {
        border-radius: 36px;
        padding: 3rem;
        background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(238,248,255,0.96));
        box-shadow: 0 25px 65px rgba(15,23,42,0.1);
        border: 1px solid rgba(226,232,240,0.9);
    }

    .contact-avatar {
        width: 86px;
        height: 86px;
        border-radius: 28px;
        background: linear-gradient(135deg, var(--fc-blue), var(--fc-cyan));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2.2rem;
        font-weight: 900;
        margin: 0 auto 1.5rem;
        box-shadow: 0 18px 35px rgba(0,120,212,0.28);
    }

    @@media (max-width: 991.98px) {
        .lux-hero {
            min-height: auto;
            background: linear-gradient(rgba(7,31,47,0.9), rgba(7,31,47,0.9)), url('/images/hero_doctor.png');
            background-size: cover;
            background-position: center;
        }

        .lux-title {
            letter-spacing: -2px;
        }

        .hero-stat-bar {
            margin-top: 2rem;
        }

        .stat-item {
            border-right: 0;
            border-bottom: 1px solid rgba(15,23,42,0.08);
        }

            .stat-item:last-child {
                border-bottom: 0;
            }
    }
</style>

<section id="top" class="lux-hero">
    <div class="container">
        <div class="hero-inner">
            <span class="eyebrow">Telemedicine for Senior Citizens in Ventspils</span>

            <h1 class="lux-title">
                Online care with <span>FreyaCare</span>
            </h1>

            <p class="lux-lead">
                Book consultations, meet doctors online, and view prescriptions and medical notes
                from the comfort of your home through a calm, simple, and accessible healthcare platform.
            </p>

            <div class="hero-actions">
                <a asp-controller="Auth" asp-action="Register" class="btn btn-lux-primary btn-lg">
                    Get Started
                </a>

                <a asp-controller="Auth" asp-action="Login" class="btn btn-lux-light btn-lg">
                    Login
                </a>
            </div>
        </div>
    </div>
</section>

<section class="hero-stat-bar">
    <div class="container">
        <div class="stat-wrap">
            <div class="row text-center">
                <div class="col-lg-3 col-md-6 stat-item">
                    <div class="stat-number">01</div>
                    <p class="stat-label">Register securely</p>
                </div>

                <div class="col-lg-3 col-md-6 stat-item">
                    <div class="stat-number">02</div>
                    <p class="stat-label">Book a doctor</p>
                </div>

                <div class="col-lg-3 col-md-6 stat-item">
                    <div class="stat-number">03</div>
                    <p class="stat-label">Join online</p>
                </div>

                <div class="col-lg-3 col-md-6 stat-item">
                    <div class="stat-number">04</div>
                    <p class="stat-label">View results</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="lux-section">
    <div class="container">
        <div class="row align-items-end mb-5">
            <div class="col-lg-7">
                <p class="section-kicker">Designed for elderly users</p>
                <h2 class="section-title">Healthcare made easier for seniors.</h2>
            </div>

            <div class="col-lg-5">
                <p class="section-copy mb-0">
                    FreyaCare uses clear navigation, readable text, simple forms, and direct actions
                    so elderly patients can access care with confidence.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="lux-card">
                    <img src="~/images/senior_woman.jpg" alt="Senior woman using FreyaCare" />
                    <div class="lux-card-body">
                        <h3>Simple registration</h3>
                        <p>
                            Patients can create an account using their personal code and password,
                            then access their appointment area easily.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="lux-card">
                    <img src="~/images/hero_doctor.png" alt="Online doctor consultation" />
                    <div class="lux-card-body">
                        <h3>Online consultation</h3>
                        <p>
                            Patients can book a doctor and join an online consultation using a generated
                            meeting link.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="lux-card">
                    <img src="~/images/senior_man.jpg" alt="Senior man using telemedicine" />
                    <div class="lux-card-body">
                        <h3>Clear results</h3>
                        <p>
                            After consultation, patients can review doctor notes, diagnosis, and
                            prescriptions from their account.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="lux-section pt-0">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-kicker">How FreyaCare works</p>
            <h2 class="section-title">A simple care journey.</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">01</div>
                    <h3>Register</h3>
                    <p>Create an account using your personal code and password.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">02</div>
                    <h3>Book</h3>
                    <p>Choose a doctor and book a consultation time.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">03</div>
                    <h3>Consult</h3>
                    <p>Join your online consultation from home.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="step-card">
                    <div class="step-number">04</div>
                    <h3>Results</h3>
                    <p>Read doctor notes, diagnosis, and prescriptions.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="dark-feature">
    <div class="container">
        <div class="row justify-content-end">
            <div class="col-lg-7">
                <div class="dark-panel">
                    <p class="eyebrow">Comfort, clarity, and remote access</p>

                    <h2>Care from home, without difficult travel.</h2>

                    <p class="mt-4">
                        FreyaCare reduces the need for unnecessary hospital visits and helps elderly
                        citizens receive medical support from familiar surroundings.
                    </p>

                    <ul class="feature-list">
                        <li>
                            <span class="check-dot">✓</span>
                            <span>Remote consultations reduce unnecessary travel.</span>
                        </li>

                        <li>
                            <span class="check-dot">✓</span>
                            <span>Doctors can review appointments and provide follow-up notes.</span>
                        </li>

                        <li>
                            <span class="check-dot">✓</span>
                            <span>Patients can access prescriptions and consultation results online.</span>
                        </li>
                    </ul>

                    <div class="mt-4">
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-lux-primary btn-lg">
                            Access Your Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="lux-section">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-kicker">Contact</p>
            <h2 class="section-title">Need support?</h2>
            <p class="section-copy mx-auto" style="max-width: 700px;">
                If you have questions about FreyaCare or need help using the platform,
                you can reach the project author below.
            </p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="contact-card text-center">
                    <div class="contact-avatar">M</div>

                    <h4 class="fw-bold mb-2">Martin McJude Onyeche</h4>

                    <p class="section-copy mb-1">Inzenieru iela 101</p>
                    <p class="section-copy mb-4">Ventspils, LV-3601</p>

                    <a href="#top" class="btn btn-lux-primary">
                        Back to Top
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>