@model IEnumerable<FreyaCare.Models.Appointment>

@{
    ViewData["Title"] = "Manage Appointments";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="mb-4">Manage Appointments</h2>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Consultation Type</th>
                            <th style="width: 140px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Patient?.FullName</td>
                                <td>@item.Doctor?.FullName</td>
                                <td>@item.AppointmentDate</td>
                                <td>
                                    <span class="badge bg-secondary">@item.Status</span>
                                </td>
                                <td>@item.ConsultationType</td>
                                <td>
                                    <a asp-action="DeleteAppointment"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <a asp-action="Dashboard" class="btn btn-outline-primary mt-3">Back to Dashboard</a>
        </div>
    </div>
</div>
