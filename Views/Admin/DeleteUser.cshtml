@model FreyaCare.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">
                    <h2 class="text-danger mb-4">Delete User</h2>

                    <p class="fs-5">Are you sure you want to delete this user?</p>

                    <div class="mb-3">
                        <strong>Name:</strong> @Model.FullName
                    </div>

                    <div class="mb-3">
                        <strong>Personal Code:</strong> @Model.PersonalCode
                    </div>

                    <div class="mb-3">
                        <strong>Role:</strong> @Model.Role
                    </div>

                    <form asp-action="DeleteUser" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg">Delete</button>
                        <a asp-action="Users" class="btn btn-outline-secondary btn-lg ms-2">Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>