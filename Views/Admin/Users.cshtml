@model IEnumerable<FreyaCare.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="mb-4">Manage Users</h2>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Personal Code</th>
                            <th>Role</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.PersonalCode</td>
                                <td>
                                    <span class="badge bg-secondary">@user.Role</span>
                                </td>
                                <td>@user.PhoneNumber</td>
                                <td>@user.Email</td>
                                <td>
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-warning me-2">Edit</a>
                                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <a asp-action="Dashboard" class="btn btn-outline-primary mt-3">Back to Dashboard</a>
        </div>
    </div>
</div>