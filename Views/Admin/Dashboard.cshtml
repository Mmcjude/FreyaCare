@model IEnumerable<FreyaCare.Models.Appointment>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    :root {
        --fc-navy: #071f2f;
        --fc-blue: #0078d4;
        --fc-cyan: #66d9ff;
        --fc-bg: #f6fbff;
        --fc-text: #132733;
        --fc-muted: #6b7280;
        --fc-border: #e5edf3;
    }

    body {
        background: var(--fc-bg);
    }

    .dash-wrap {
        min-height: 100vh;
        display: flex;
        background: radial-gradient(circle at top right, rgba(102,217,255,0.10), transparent 30%), #f6fbff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .sidebar {
        width: 240px;
        min-height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        padding: 22px 16px;
        background: linear-gradient(180deg, #071f2f, #0d344b);
        color: white;
        box-shadow: 12px 0 30px rgba(7,31,47,0.12);
        transition: transform 0.3s ease;
        z-index: 1000;
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-bottom: 20px;
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.14);
    }

    .logo-mark {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--fc-blue), var(--fc-cyan));
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .logo-mark i {
            color: white;
            font-size: 1.1rem;
        }

    .logo-text {
        font-size: 1.05rem;
        font-weight: 800;
        line-height: 1;
    }

    .logo-sub {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.65);
        margin-top: 4px;
    }

    .nav-section {
        margin-bottom: 22px;
    }

    .nav-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--fc-cyan);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 8px;
        padding-left: 8px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 12px;
        border-radius: 12px;
        color: rgba(255,255,255,0.78);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 0.2s ease;
        margin-bottom: 6px;
    }

        .nav-item i {
            width: 18px;
            text-align: center;
            font-size: 1rem;
        }

        .nav-item:hover {
            color: white;
            background: rgba(255,255,255,0.10);
            text-decoration: none;
        }

        .nav-item.active {
            color: white;
            background: rgba(102,217,255,0.18);
            border: 1px solid rgba(102,217,255,0.25);
            box-shadow: 0 0 20px rgba(102,217,255,0.08);
        }

    .main-content {
        margin-left: 240px;
        width: calc(100% - 240px);
        padding: 32px;
        transition: all 0.3s ease;
    }

    .sidebar-hidden .sidebar {
        transform: translateX(-100%);
    }

    .sidebar-hidden .main-content {
        margin-left: 0;
        width: 100%;
    }

    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 28px;
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .sidebar-toggle {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        border: 1px solid var(--fc-border);
        background: white;
        color: var(--fc-text);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        box-shadow: 0 10px 25px rgba(15,23,42,0.06);
        transition: all 0.2s ease;
    }

        .sidebar-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 35px rgba(15,23,42,0.10);
        }

    .eyebrow {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.72rem;
        font-weight: 800;
        color: var(--fc-blue);
        margin-bottom: 8px;
    }

    .topbar-title {
        font-size: 2rem;
        line-height: 1.1;
        font-weight: 800;
        color: var(--fc-text);
    }

    .topbar-sub {
        font-size: 0.95rem;
        color: var(--fc-muted);
        margin-top: 8px;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--fc-blue), var(--fc-cyan));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        font-weight: 800;
        color: white;
        flex-shrink: 0;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 14px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: white;
        border: 1px solid var(--fc-border);
        border-radius: 20px;
        padding: 18px;
        box-shadow: 0 14px 35px rgba(15,23,42,0.06);
        transition: all 0.2s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(15,23,42,0.10);
        }

    .stat-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--fc-muted);
        margin-bottom: 8px;
    }

    .stat-value {
        font-size: 1.9rem;
        line-height: 1;
        font-weight: 800;
        color: var(--fc-text);
    }

    .stat-note {
        font-size: 0.78rem;
        color: var(--fc-blue);
        font-weight: 600;
        margin-top: 9px;
    }

    .section-head {
        margin-bottom: 18px;
    }

    .section-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: var(--fc-text);
        margin-bottom: 5px;
    }

    .section-sub {
        font-size: 0.95rem;
        color: var(--fc-muted);
    }

    .action-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
        margin-bottom: 32px;
    }

    .action-card {
        background: white;
        border: 1px solid var(--fc-border);
        border-radius: 22px;
        padding: 22px;
        text-decoration: none;
        color: inherit;
        box-shadow: 0 14px 35px rgba(15,23,42,0.06);
        transition: all 0.2s ease;
    }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 45px rgba(15,23,42,0.10);
            text-decoration: none;
            color: inherit;
        }

    .action-icon {
        width: 50px;
        height: 50px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
        background: linear-gradient(135deg, var(--fc-blue), var(--fc-cyan));
        margin-bottom: 16px;
    }

    .action-name {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--fc-text);
        margin-bottom: 8px;
    }

    .action-link {
        display: inline-block;
        margin-top: 6px;
        font-size: 0.95rem;
        color: var(--fc-blue);
        font-weight: 800;
    }

    .recent-section {
        margin-top: 10px;
    }

    .recent-card {
        background: white;
        border: 1px solid var(--fc-border);
        border-radius: 22px;
        padding: 8px;
        box-shadow: 0 14px 35px rgba(15,23,42,0.06);
        overflow: hidden;
    }

        .recent-card table {
            font-size: 0.92rem;
        }

        .recent-card thead th {
            color: var(--fc-muted);
            font-size: 0.8rem;
            font-weight: 800;
            border-bottom: 1px solid var(--fc-border);
            padding: 14px;
        }

        .recent-card tbody td {
            padding: 14px;
            color: var(--fc-text);
            border-bottom: 1px solid #eef3f7;
        }

        .recent-card tbody tr:last-child td {
            border-bottom: none;
        }

    .status-pill {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
    }

    .status-pending {
        background: #fff7e6;
        color: #b26a00;
    }

    .status-completed {
        background: #e8f8ef;
        color: #16824a;
    }

    .status-cancelled {
        background: #fdecec;
        color: #b42318;
    }

    @@media (max-width: 1200px) {
        .stats-row {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 991.98px) {
        .dash-wrap {
            display: block;
        }

        .sidebar {
            position: relative;
            width: 100%;
            min-height: auto;
            transform: none !important;
        }

        .sidebar-hidden .sidebar {
            display: none;
        }

        .main-content,
        .sidebar-hidden .main-content {
            margin-left: 0;
            width: 100%;
            padding: 24px;
        }

        .stats-row,
        .action-grid {
            grid-template-columns: 1fr;
        }

        .topbar {
            align-items: flex-start;
        }
    }
</style>

<div class="dash-wrap">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-mark">
                <i class="bi bi-shield-fill"></i>
            </div>

            <div>
                <div class="logo-text">FreyaCare</div>
                <div class="logo-sub">Admin panel</div>
            </div>
        </div>

        <div class="nav-section">
            <div class="nav-label">Overview</div>

            <a class="nav-item active" asp-controller="Admin" asp-action="Dashboard">
                <i class="bi bi-grid-fill"></i>
                <span>Dashboard</span>
            </a>
        </div>

        <div class="nav-section">
            <div class="nav-label">Management</div>

            <a class="nav-item" asp-controller="Admin" asp-action="Users">
                <i class="bi bi-people"></i>
                <span>Users</span>
            </a>

            <a class="nav-item" asp-controller="Admin" asp-action="Appointments">
                <i class="bi bi-calendar-check"></i>
                <span>Appointments</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <div class="topbar">
            <div class="topbar-left">
                <button type="button" class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>

                <div>
                    <span class="eyebrow">System overview</span>

                    <div class="topbar-title">
                        Admin dashboard
                    </div>

                    <div class="topbar-sub">
                        Live overview of FreyaCare users and consultation activity.
                    </div>
                </div>
            </div>

            <div class="avatar">AD</div>
        </div>

        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-label">Patients</div>
                <div class="stat-value">@ViewBag.PatientCount</div>
                <div class="stat-note">Registered users</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Doctors</div>
                <div class="stat-value">@ViewBag.DoctorCount</div>
                <div class="stat-note">Care providers</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Appointments</div>
                <div class="stat-value">@ViewBag.AppointmentCount</div>
                <div class="stat-note">Total records</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Today</div>
                <div class="stat-value">@ViewBag.TodayAppointments</div>
                <div class="stat-note">Scheduled today</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Pending</div>
                <div class="stat-value">@ViewBag.PendingAppointments</div>
                <div class="stat-note">Awaiting consult</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Completed</div>
                <div class="stat-value">@ViewBag.CompletedAppointments</div>
                <div class="stat-note">Finished consults</div>
            </div>
        </div>

        <div class="section-head">
            <div class="section-title">Management tools</div>
        </div>

        <div class="action-grid">
            <a class="action-card" asp-controller="Admin" asp-action="Users">
                <div class="action-icon">
                    <i class="bi bi-people"></i>
                </div>

                <div class="action-name">Manage users</div>
                <div class="action-link">Open users &rarr;</div>
            </a>

            <a class="action-card" asp-controller="Admin" asp-action="Appointments">
                <div class="action-icon">
                    <i class="bi bi-calendar-check"></i>
                </div>

                <div class="action-name">Manage appointments</div>
                <div class="action-link">Open appointments &rarr;</div>
            </a>
        </div>

        <div class="recent-section">
            <div class="section-head">
                <div class="section-title">Recent appointments</div>
                <div class="section-sub">
                    Latest consultation activity in the FreyaCare system.
                </div>
            </div>

            <div class="recent-card">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var appointment in Model)
                            {
                                var statusClass = appointment.Status?.ToLower() ?? "pending";

                                <tr>
                                    <td>@appointment.Patient?.FullName</td>
                                    <td>@appointment.Doctor?.FullName</td>
                                    <td>@appointment.AppointmentDate.ToString("dd MMM yyyy, HH:mm")</td>
                                    <td>
                                        <span class="status-pill status-@statusClass">
                                            @appointment.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    No appointments have been created yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<script>
    const sidebarToggle = document.getElementById("sidebarToggle");

    sidebarToggle.addEventListener("click", function () {
        document.body.classList.toggle("sidebar-hidden");
    });
</script>