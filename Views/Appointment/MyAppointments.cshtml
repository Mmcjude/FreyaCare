@model IEnumerable<FreyaCare.Models.Appointment>

@{
    ViewData["Title"] = "My Appointments";
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-body">
            <h2 class="mb-4">My Appointments</h2>

            <a asp-action="Book" class="btn btn-primary mb-3">Book New Consultation</a>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Meeting</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Doctor?.FullName</td>
                            <td>@item.AppointmentDate</td>
                            <td>@item.Status</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.MeetingLink))
                                {
                                    <a href="@item.MeetingLink" target="_blank" class="btn btn-success btn-sm">Join</a>
                                }
                            </td>
                            <td>
                                <a asp-action="ViewResult" asp-route-id="@item.Id" class="btn btn-info btn-sm">View Result</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>